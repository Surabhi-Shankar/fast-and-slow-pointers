class Solution {
    public boolean isPalindrome(Node head) {
        Node slow = head;
        Node fast = head;
        while(fast != null && fast.next != null){
            slow = slow.next;
            fast = fast.next.next;
        }
        Node prev = null;
        while (slow != null) {
            Node nextTemp = slow.next;
            slow.next = prev;
            prev = slow;
            slow = nextTemp;
        }
        Node left = head;
        Node right = prev;
        while (right != null) { 
            if (left.data != right.data) { 
                return false;
            }
            left = left.next;
            right = right.next;
        }
        return true;
    }
}
