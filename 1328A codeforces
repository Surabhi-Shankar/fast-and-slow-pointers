import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        if (sc.hasNextInt()) {
            int t = sc.nextInt();
            while (t-- > 0) {
                int a = sc.nextInt();
                int b = sc.nextInt();
                if (a % b == 0) {
                    System.out.println(0);
                } else {
                    int moves = b - (a % b);
                    System.out.println(moves);
                }
            }
        }
        sc.close();
    }
}
